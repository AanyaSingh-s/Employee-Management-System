      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-sand: #F4F1EA;\n    --color-offwhite: #FCFBF9;\n    --color-assam: #5C4033;\n    --color-forest: #2E473B;\n    --color-espresso: #2C241B;\n  }\n\n  body {\n    font-family: 'Outfit', sans-serif;\n    color: var(--color-espresso);\n    background-color: var(--color-sand);\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-serif {\n    font-family: 'Lora', serif;\n  }\n\n  .animate-entrance {\n    animation: entrance 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;\n  }\n\n  @keyframes entrance {\n    from {\n      opacity: 0;\n      transform: translateY(20px);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  .sidebar-floating {\n    height: calc(100% - 40px);\n    max-height: 900px;\n    margin: 20px;\n    border-radius: 40px;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--color-sand);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(92, 64, 51, 0.1);\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: rgba(92, 64, 51, 0.2);\n  }\n</style>\n\n<div class=\"flex bg-[var(--color-sand)] font-sans\" data-kid=\"1\">\n  \n  <aside class=\"hidden lg:flex flex-col w-80 bg-[var(--color-offwhite)] sidebar-floating border border-[var(--color-assam)]/5 shadow-xl shadow-[var(--color-assam)]/5 shrink-0\" data-kid=\"2\">\n    <div class=\"p-10 pb-4 text-center\" data-kid=\"3\">\n      <div class=\"inline-flex items-center justify-center w-16 h-16 bg-[var(--color-assam)] text-white rounded-[20px] mb-5 shadow-xl shadow-[var(--color-assam)]/20\" data-kid=\"4\">\n        <i class=\"ti ti-coffee text-3xl\" data-kid=\"5\"></i>\n      </div>\n      <h2 class=\"font-serif text-2xl font-semibold text-[var(--color-espresso)] leading-tight\" data-kid=\"6\">Roast & Records</h2>\n      <p class=\"text-[10px] text-[var(--color-assam)]/40 tracking-[0.2em] uppercase font-black mt-2\" data-kid=\"7\">Enterprise EMS</p>\n    </div>\n\n    <nav class=\"flex-1 px-8 py-10 space-y-4\" data-kid=\"8\">\n      <a href=\"#\" class=\"flex items-center space-x-4 px-6 py-4 bg-[var(--color-assam)] text-white rounded-full transition-all duration-300 shadow-xl shadow-[var(--color-assam)]/25 group\" data-kid=\"9\">\n        <i class=\"ti ti-users text-2xl group-hover:scale-110 transition-transform\" data-kid=\"10\"></i>\n        <span class=\"font-semibold text-base\" data-kid=\"11\">Employees</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center space-x-4 px-6 py-4 text-[var(--color-espresso)]/50 hover:bg-[var(--color-assam)]/5 hover:text-[var(--color-assam)] rounded-full transition-all duration-300 group\" data-kid=\"12\">\n        <i class=\"ti ti-book-2 text-2xl group-hover:scale-110 transition-transform\" data-kid=\"13\"></i>\n        <span class=\"font-semibold text-base\" data-kid=\"14\">Resources</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center space-x-4 px-6 py-4 text-[var(--color-espresso)]/50 hover:bg-[var(--color-assam)]/5 hover:text-[var(--color-assam)] rounded-full transition-all duration-300 group\" data-kid=\"15\">\n        <i class=\"ti ti-sun text-2xl group-hover:scale-110 transition-transform\" data-kid=\"16\"></i>\n        <span class=\"font-semibold text-base\" data-kid=\"17\">Attendance</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center space-x-4 px-6 py-4 text-[var(--color-espresso)]/50 hover:bg-[var(--color-assam)]/5 hover:text-[var(--color-assam)] rounded-full transition-all duration-300 group\" data-kid=\"18\">\n        <i class=\"ti ti-report-search text-2xl group-hover:scale-110 transition-transform\" data-kid=\"19\"></i>\n        <span class=\"font-semibold text-base\" data-kid=\"20\">Reports</span>\n      </a>\n    </nav>\n\n    <div class=\"p-8 m-6 bg-[var(--color-sand)]/50 rounded-[2.5rem] border border-[var(--color-assam)]/10\" data-kid=\"21\">\n      <div class=\"flex items-center space-x-4\" data-kid=\"22\">\n        <img src=\"https://i.pravatar.cc/100?u=admin\" alt=\"Sarah Brew\" class=\"w-12 h-12 rounded-full border-2 border-[var(--color-offwhite)] shadow-sm\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n        <div class=\"overflow-hidden\" data-kid=\"24\">\n          <p class=\"text-base font-bold text-[var(--color-espresso)] truncate\" data-kid=\"25\">Sarah Brew</p>\n          <p class=\"text-[10px] text-[var(--color-assam)]/60 font-black uppercase tracking-widest\" data-kid=\"26\">Administrator</p>\n        </div>\n      </div>\n      <button class=\"w-full mt-5 py-2.5 text-xs font-black text-[var(--color-assam)]/60 hover:text-[var(--color-assam)] transition-colors flex items-center justify-center space-x-2 uppercase tracking-widest border-t border-[var(--color-assam)]/5 pt-5\" data-kid=\"27\">\n        <i class=\"ti ti-logout text-lg\" data-kid=\"28\"></i>\n        <span data-kid=\"29\">Sign Out</span>\n      </button>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 p-10 lg:pl-5\" data-kid=\"30\">\n    <div class=\"max-w-7xl mx-auto space-y-12\" data-kid=\"31\">\n      \n      \n      <header class=\"animate-entrance relative bg-[var(--color-offwhite)] rounded-[3rem] overflow-hidden border border-[var(--color-assam)]/10 shadow-sm min-h-[340px] flex items-center\" data-kid=\"32\">\n        <div class=\"w-full lg:w-2/3 p-12 lg:p-20 z-10\" data-kid=\"33\">\n          <div class=\"inline-flex items-center space-x-3 px-5 py-2 bg-[var(--color-assam)]/10 text-[var(--color-assam)] rounded-full text-[10px] font-black uppercase tracking-widest mb-8\" data-kid=\"34\">\n            <span class=\"relative flex h-2.5 w-2.5\" data-kid=\"35\">\n              <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-assam)]/40 opacity-75\" data-kid=\"36\"></span>\n              <span class=\"relative inline-flex rounded-full h-2.5 w-2.5 bg-[var(--color-assam)]\" data-kid=\"37\"></span>\n            </span>\n            <span data-kid=\"38\">Status: Connected</span>\n          </div>\n          <h1 class=\"text-4xl lg:text-6xl font-serif text-[var(--color-espresso)] leading-tight mb-8 italic\" data-kid=\"39\">Welcome back, Sarah.</h1>\n          <p class=\"text-[var(--color-espresso)]/60 text-lg lg:text-2xl max-w-xl font-light leading-relaxed\" data-kid=\"40\">\n            Our teams are brewing something special today. You have <span class=\"text-[var(--color-assam)] font-bold\" data-kid=\"41\">4 new applicants</span> awaiting your review.\n          </p>\n          <div class=\"mt-12 flex flex-wrap items-center gap-5\" data-kid=\"42\">\n            <button class=\"px-12 py-5 bg-[var(--color-forest)] text-white rounded-full font-bold shadow-xl shadow-[var(--color-forest)]/30 hover:bg-[var(--color-forest)]/90 transition-all flex items-center space-x-3 group\" data-kid=\"43\">\n              <i class=\"ti ti-users-plus text-2xl group-hover:rotate-12 transition-transform\" data-kid=\"44\"></i>\n              <span class=\"text-lg\" data-kid=\"45\">Onboard Artisan</span>\n            </button>\n            <button class=\"px-10 py-5 bg-[var(--color-sand)] text-[var(--color-assam)] rounded-full font-bold hover:bg-[var(--color-assam)]/10 transition-all border border-[var(--color-assam)]/10 text-lg\" data-kid=\"46\">\n              Generate Report\n            </button>\n          </div>\n        </div>\n        <div class=\"hidden lg:block absolute right-0 top-0 bottom-0 w-1/3\" data-kid=\"47\">\n          <img src=\"https://images.unsplash.com/photo-1758691736979-ff263c04b3d1?auto=format&w=800&q=80&fit=crop\" alt=\"Sunlit hallway\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n          <div class=\"absolute inset-0 bg-gradient-to-l from-transparent via-[var(--color-offwhite)]/20 to-[var(--color-offwhite)]\" data-kid=\"49\"></div>\n        </div>\n      </header>\n\n      \n      <section class=\"animate-entrance [animation-delay:100ms] flex flex-col md:flex-row items-center gap-6 bg-[var(--color-offwhite)]/80 p-5 rounded-[4.5rem] border border-[var(--color-assam)]/10 shadow-sm\" data-kid=\"50\">\n        <div class=\"relative flex-1 w-full group\" data-kid=\"51\">\n          <i class=\"ti ti-search absolute left-8 top-1/2 -translate-y-1/2 text-[var(--color-assam)]/60 group-focus-within:text-[var(--color-assam)] transition-colors text-2xl\" data-kid=\"52\"></i>\n          <input type=\"text\" placeholder=\"Search by name, role, or ID...\" class=\"w-full pl-18 pr-10 py-6 bg-[var(--color-sand)]/50 rounded-full border-none focus:ring-4 focus:ring-[var(--color-assam)]/10 text-[var(--color-espresso)] placeholder-[var(--color-assam)]/60 outline-none transition-all text-xl\" data-kid=\"53\">\n        </div>\n        <div class=\"flex items-center gap-5 w-full md:w-auto\" data-kid=\"54\">\n          <div class=\"relative w-full md:w-80 group\" data-kid=\"55\">\n            <i class=\"ti ti-apps absolute left-8 top-1/2 -translate-y-1/2 text-[var(--color-assam)]/50 text-2xl\" data-kid=\"56\"></i>\n            <select class=\"w-full pl-18 pr-14 py-6 bg-[var(--color-sand)]/50 rounded-full border-none focus:ring-4 focus:ring-[var(--color-assam)]/10 text-[var(--color-espresso)] outline-none appearance-none font-bold cursor-pointer text-xl\" data-kid=\"57\">\n              <option data-kid=\"58\">All Departments</option>\n              <option data-kid=\"59\">Brewery</option>\n              <option data-kid=\"60\">Logistics</option>\n              <option data-kid=\"61\">Customer Relations</option>\n              <option data-kid=\"62\">Administration</option>\n            </select>\n            <i class=\"ti ti-chevron-down absolute right-10 top-1/2 -translate-y-1/2 text-[var(--color-assam)]/40 pointer-events-none\" data-kid=\"63\"></i>\n          </div>\n          <button class=\"p-6 bg-[var(--color-assam)]/10 text-[var(--color-assam)] rounded-full hover:bg-[var(--color-assam)] transition-all hover:text-white shadow-sm group shrink-0\" data-kid=\"64\">\n            <i class=\"ti ti-refresh text-2xl group-active:rotate-180 transition-transform duration-500\" data-kid=\"65\"></i>\n          </button>\n        </div>\n      </section>\n\n      \n      <section class=\"animate-entrance [animation-delay:200ms]\" data-kid=\"66\">\n        <div class=\"flex items-center justify-between mb-10 px-4\" data-kid=\"67\">\n          <div data-kid=\"68\">\n            <h2 class=\"text-3xl font-serif text-[var(--color-espresso)]\" data-kid=\"69\">Employee Roster</h2>\n            <p class=\"text-[var(--color-assam)]/50 text-lg mt-1 font-medium italic\" data-kid=\"70\">Managing our human essence.</p>\n          </div>\n          <div class=\"flex items-center space-x-3\" data-kid=\"71\">\n            <button class=\"w-12 h-12 rounded-full bg-[var(--color-offwhite)] shadow-sm border border-[var(--color-assam)]/10 flex items-center justify-center text-[var(--color-assam)] hover:bg-[var(--color-assam)] hover:text-white transition-all\" data-kid=\"72\">\n              <i class=\"ti ti-layout-grid text-xl\" data-kid=\"73\"></i>\n            </button>\n            <button class=\"w-12 h-12 rounded-full bg-[var(--color-sand)] flex items-center justify-center hover:bg-[var(--color-assam)]/5 transition-all text-[var(--color-assam)]/40\" data-kid=\"74\">\n              <i class=\"ti ti-list text-xl\" data-kid=\"75\"></i>\n            </button>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8\" data-kid=\"76\">\n          \n          <div class=\"group bg-[var(--color-offwhite)] rounded-[3rem] p-10 border border-[var(--color-assam)]/10 shadow-sm hover:shadow-2xl 