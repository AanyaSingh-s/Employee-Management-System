      "html": "\n<body class=\"bg-[#F5F5F0] text-black font-['Space_Grotesk'] antialiased\">\n  <style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-mono { font-family: 'JetBrains Mono', monospace; }\n    .font-space { font-family: 'Space Grotesk', sans-serif; }\n\n    /* Custom Scrollbar for Neo-Brutalism */\n    ::-webkit-scrollbar { width: 12px; height: 12px; }\n    ::-webkit-scrollbar-track { background: #F5F5F0; border-left: 2px solid black; }\n    ::-webkit-scrollbar-thumb { background: black; border: 2px solid #F5F5F0; }\n\n    .neo-border { border: 2px solid black; }\n    .neo-shadow { box-shadow: 4px 4px 0px 0px rgba(0,0,0,1); }\n    .neo-shadow-hover:hover { box-shadow: 6px 6px 0px 0px rgba(0,0,0,1); transform: translate(-2px, -2px); }\n\n    .btn-brutal {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      border: 2px solid black;\n      font-weight: 700;\n      text-transform: uppercase;\n      cursor: pointer;\n      transition: all 0.1s ease;\n      letter-spacing: 0.05em;\n    }\n\n    .table-row-hover { position: relative; }\n    .table-row-hover:hover::after {\n      content: \"\";\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      width: 100%;\n      height: 4px;\n      background-image: radial-gradient(circle, black 2px, transparent 2px);\n      background-size: 8px 4px;\n      z-index: 10;\n    }\n    .btn-brutal:hover {\n      background: black !important;\n      color: white !important;\n    }\n    .btn-brutal:active {\n      transform: translate(1px, 1px);\n    }\n  </style>\n\n  <div class=\"max-w-[1440px] mx-auto min-h-[1600px] border-x-2 border-black bg-[#F5F5F0]\" data-kid=\"1\">\n    \n    \n    <header class=\"h-[80px] border-b-2 border-black flex items-center bg-white px-8 relative z-50 overflow-hidden\" data-kid=\"2\">\n      \n      <span class=\"absolute top-0 left-0 w-2 h-2 border-r-2 border-b-2 border-black\" data-kid=\"3\"></span>\n      <span class=\"absolute top-0 right-0 w-2 h-2 border-l-2 border-b-2 border-black\" data-kid=\"4\"></span>\n      <div class=\"flex items-center gap-16 h-full w-full\" data-kid=\"5\">\n        \n        <div class=\"flex items-center gap-3\" data-kid=\"6\">\n          <div class=\"w-10 h-10 bg-black flex items-center justify-center\" data-kid=\"7\">\n            <i class=\"ti ti-cpu text-white text-2xl\" data-kid=\"8\"></i>\n          </div>\n          <span class=\"text-2xl font-bold tracking-tighter uppercase font-space\" data-kid=\"9\">Theatre_EMS</span>\n        </div>\n\n        \n        <nav class=\"flex gap-12 h-full\" data-kid=\"10\">\n          <a href=\"#\" class=\"flex flex-col justify-center h-full group relative\" data-kid=\"11\">\n            <span class=\"font-mono text-[10px] text-gray-400 mb-0.5\" data-kid=\"12\">01</span>\n            <span class=\"text-xs font-bold tracking-[0.2em] group-hover:text-black\" data-kid=\"13\">DASHBOARD</span>\n          </a>\n          <a href=\"#\" class=\"flex flex-col justify-center h-full group relative border-b-4 border-black\" data-kid=\"14\">\n            <span class=\"font-mono text-[10px] text-black mb-0.5\" data-kid=\"15\">02</span>\n            <span class=\"text-xs font-bold tracking-[0.2em]\" data-kid=\"16\">EMPLOYEES</span>\n          </a>\n          <a href=\"#\" class=\"flex flex-col justify-center h-full group relative\" data-kid=\"17\">\n            <span class=\"font-mono text-[10px] text-gray-400 mb-0.5\" data-kid=\"18\">03</span>\n            <span class=\"text-xs font-bold tracking-[0.2em] group-hover:text-black\" data-kid=\"19\">PAYROLL</span>\n          </a>\n          <a href=\"#\" class=\"flex flex-col justify-center h-full group relative\" data-kid=\"20\">\n            <span class=\"font-mono text-[10px] text-gray-400 mb-0.5\" data-kid=\"21\">04</span>\n            <span class=\"text-xs font-bold tracking-[0.2em] group-hover:text-black\" data-kid=\"22\">LOGISTICS</span>\n          </a>\n        </nav>\n\n        \n        <div class=\"ml-auto flex items-center gap-6\" data-kid=\"23\">\n          <div class=\"hidden lg:flex flex-col items-end\" data-kid=\"24\">\n            <span class=\"font-mono text-sm font-bold tracking-tighter\" data-kid=\"25\">14:52:11</span>\n            <span class=\"text-[9px] font-mono text-gray-500 uppercase tracking-widest\" data-kid=\"26\">SERVER_TIME_STABLE</span>\n          </div>\n          <div class=\"h-10 w-[2px] bg-black/10\" data-kid=\"27\"></div>\n          <div class=\"flex items-center gap-3\" data-kid=\"28\">\n            <div class=\"text-right hidden sm:block\" data-kid=\"29\">\n              <p class=\"text-[11px] font-bold leading-none uppercase\" data-kid=\"30\">Admin_Node_01</p>\n              <p class=\"text-[9px] font-mono text-[#FF5722]\" data-kid=\"31\">LEVEL_7_ACCESS</p>\n            </div>\n            <div class=\"w-10 h-10 border-2 border-black bg-white flex items-center justify-center\" data-kid=\"32\">\n              <i class=\"ti ti-database text-lg\" data-kid=\"33\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n    </header>\n\n    <main class=\"p-8 lg:p-12 space-y-12\" data-kid=\"34\">\n      \n      \n      <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-0 border-2 border-black overflow-hidden bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative\" data-kid=\"35\">\n        \n        <span class=\"absolute top-0 left-0 w-4 h-4 border-r-2 border-b-2 border-black z-10\" data-kid=\"36\"></span>\n        \n        <div class=\"lg:col-span-7 p-8 lg:p-14 border-r-2 border-black relative min-h-[450px] flex flex-col justify-center\" data-kid=\"37\">\n          \n          <div class=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none\" data-kid=\"38\">\n            <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/crosshair.svg\" class=\"w-64 h-64\" style=\"filter: invert(1);\" data-kid=\"39\">\n          </div>\n          <div class=\"absolute bottom-6 left-8 flex gap-2 items-center opacity-40\" data-kid=\"40\">\n             <span class=\"w-3 h-3 border-2 border-black\" data-kid=\"41\"></span>\n             <span class=\"text-[10px] font-mono font-bold tracking-widest uppercase\" data-kid=\"42\">STAG_MONITOR_00</span>\n          </div>\n\n          <div class=\"text-[11px] font-mono mb-6 uppercase tracking-[0.3em] font-bold text-[#708090]\" data-kid=\"43\">\n            <span class=\"bg-black text-white px-2 py-0.5 mr-2\" data-kid=\"44\">LIVE</span> EMP_ENGAGEMENT_REALTIME\n          </div>\n          \n          <h1 class=\"text-8xl lg:text-[9rem] font-bold tracking-tighter leading-[0.85] mb-8\" data-kid=\"45\">\n            98%<br data-kid=\"46\">\n            <span class=\"text-5xl lg:text-7xl\" data-kid=\"47\">ATTENDANCE</span>\n          </h1>\n          \n          <div class=\"max-w-md\" data-kid=\"48\">\n            <p class=\"text-sm font-medium uppercase tracking-tight leading-relaxed text-black/80\" data-kid=\"49\">\n              The aggregate attendance rate for current operational cycle remains significantly above the 92% benchmark. \n              Efficiency parameters are optimal across all departments.\n            </p>\n          </div>\n\n          <button class=\"mt-10 self-start btn-brutal bg-white text-black px-8 py-4 text-sm tracking-widest group\" data-kid=\"50\">\n            <span data-kid=\"51\">FULL SYSTEM DIAGNOSTIC</span>\n            <i class=\"ti ti-maximize ml-3 text-lg group-hover:scale-125 transition-transform\" data-kid=\"52\"></i>\n          </button>\n        </div>\n\n        \n        <div class=\"lg:col-span-5 flex flex-col\" data-kid=\"53\">\n          \n          <div class=\"h-1/2 border-b-2 border-black relative overflow-hidden group\" data-kid=\"54\">\n            <img src=\"https://images.unsplash.com/photo-1490261704701-28a81653095c?auto=format&w=800&q=80&fit=crop\" alt=\"Arch detail\" class=\"w-full h-full object-cover grayscale brightness-90 group-hover:scale-110 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"55\">\n            <div class=\"absolute inset-0 bg-black/20 mix-blend-multiply\" data-kid=\"56\"></div>\n            <div class=\"absolute top-4 left-4 border-2 border-white bg-black/40 backdrop-blur-md px-3 py-1 text-[10px] font-mono text-white font-bold tracking-widest\" data-kid=\"57\">\n              BLDG_REF_NW_402\n            </div>\n          </div>\n          \n          <div class=\"h-1/2 grid grid-cols-2\" data-kid=\"58\">\n            <div class=\"p-8 bg-[#FF5722] text-white border-r-2 border-black flex flex-col justify-between\" data-kid=\"59\">\n              <div data-kid=\"60\">\n                <p class=\"text-[10px] font-mono font-bold tracking-widest uppercase opacity-80 mb-2\" data-kid=\"61\">LEAVE_PENDING</p>\n                <h3 class=\"text-6xl font-bold tracking-tighter leading-none\" data-kid=\"62\">03</h3>\n              </div>\n              <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"63\">REQUIRES_IMMEDIATE_ACTION</p>\n            </div>\n            <div class=\"p-8 bg-black text-white flex flex-col justify-between\" data-kid=\"64\">\n              <div data-kid=\"65\">\n                <p class=\"text-[10px] font-mono font-bold tracking-widest uppercase opacity-80 mb-2\" data-kid=\"66\">REVIEWS_LOG</p>\n                <h3 class=\"text-6xl font-bold tracking-tighter leading-none\" data-kid=\"67\">12</h3>\n              </div>\n              <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"68\">OPEN_PERFORMANCE_CYCLES</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"flex flex-col md:flex-row gap-4 items-end justify-between border-b-2 border-black pb-8\" data-kid=\"69\">\n        <div class=\"space-y-2\" data-kid=\"70\">\n          <h2 class=\"text-5xl font-bold tracking-tighter uppercase\" data-kid=\"71\">Personnel Index</h2>\n          <div class=\"flex items-center gap-4 text-[10px] font-mono font-bold text-gray-500 uppercase tracking-widest\" data-kid=\"72\">\n            <span data-kid=\"73\">TOTAL_ENTRY: 1,402</span>\n            <span class=\"w-1 h-1 bg-black rounded-full\" data-kid=\"74\"></span>\n            <span data-kid=\"75\">FILTER: ALL_ACTIVE</span>\n            <span class=\"w-1 h-1 bg-black rounded-full\" data-kid=\"76\"></span>\n            <span data-kid=\"77\">SORT: ID_ASCENDING</span>\n          </div>\n        </div>\n        \n        <div class=\"flex gap-2 w-full md:w-auto\" data-kid=\"78\">\n          <div class=\"relative flex-1 md:flex-none\" data-kid=\"79\">\n            <input type=\"text\" placeholder=\"SEARCH_INDEX...\" class=\"neo-border bg-white h-12 px-4 w-full md:w-64 font-mono text-xs uppercase focus:outline-none focus:bg-black focus:text-white transition-colors\" data-kid=\"80\">\n          </div>\n          <button class=\"btn-brutal px-6 h-12 text-xs tracking-widest bg-black text-white hover:bg-white hover:text-black\" data-kid=\"81\">\n            + NEW_RECORD\n          </button>\n          <button class=\"btn-brutal bg-white text-black px-4 h-12 text-xs\" data-kid=\"82\">\n            <i class=\"ti ti-database\" data-kid=\"83\"></i>\n          </button>\n        </div>\n      </section>\n\n      \n      <section class=\"overflow-x-auto\" data-kid=\"84\">\n        <table class=\"w-full border-collapse border-2 border-black bg-white\" data-kid=\"85\">\n          <thead data-kid=\"86\">\n            <tr class=\"bg-black text-white font-mono text-[11px] uppercase tracking-[0.2em]\" data-kid=\"87\">\n              <th class=\"p-5 text-left border-r border-white/20 w-32\" data-kid=\"88\">ID_REF</th>\n              <th class=\"p-5 text-left border-r border-white/20\" data-kid=\"89\">FULL_NAME_LABEL</th>\n              <th class=\"p-5 text-left border-r border-white/20\" data-kid=\"90\">DEPARTMENT_UNIT</th>\n              <th class=\"p-5 text-left border-r border-white/20 w-48\" data-kid=\"91\">STATUS_SIGNAL</th>\n              <th class=\"p-5 text-center w-48\" data-kid=\"92\">EXECUTE_OP</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y-2 divide-black relative\" data-kid=\"93\">\n            \n            <tr class=\"table-row-hover group cursor-pointer\" data-kid=\"94\">\n              <td class=\"p-5 font-mono text-sm border-r-2 border-black\" data-kid=\"95\">#001024</td>\n              <td class=\"p-5 border-r-2 border-black\" data-kid=\"96\">\n                <div class=\"flex items-center gap-4\" data-kid=\"97\">\n                  <div class=\"w-10 h-10 border-2 border-black bg-white flex-shrink-0\" data-kid=\"98\">\n                    <img src=\"https://images.unsplash.com/photo-1506863530036-1efeddceb993?auto=format&w=200&q=80&fit=crop\" alt=\"Alex\" class=\"w-full h-full object-cover grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"99\">\n                  </div>\n                  <div data-kid=\"100\">\n                    <p class=\"font-bold tracking-tight text-lg leading-none uppercase\" data-kid=\"101\">Alexander Vaughn</p>\n                    <p class=\"text-[10px] font-mono text-gray-500 mt-1\" data-kid=\"102\">S_ENG_L4@THEATRE.SYS</p>\n                  </div>\n                </div>\n              </td>\n              <td class=\"p-5 border-r-2 border-black\" data-kid=\"103\">\n                <span class=\"text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-black text-white\" data-kid=\"104\">Engineering</span>\n              </td>\n              <td class=\"p-5 border-r-2 border-black\" data-kid=\"105\">\n                <div class=\"flex items-center gap-2\" data-kid=\"106\">\n                  <div class=\"w-2.5 h-2.5 bg-green-500 border border-black\" data-kid=\"107\"></div>\n                  <span class=\"font-mono text-[10px] font-bold uppercase tracking-widest\" data-kid=\"108\">ACTIVE_SIGNAL</span>\n                </div>\n              </td>\n              <td class=\"p-5 text-center\" data-kid=\"109\">\n                <div class=\"flex gap-1.5 justify-center\" data-kid=\"110\">\n                  <button class=\"btn-brutal bg-white text-black px-3 py-1.5 text-[10px]\" title=\"Edit\" data-kid=\"111\">[ EDIT ]</button>\n                  <button class=\"btn-brutal bg-white text-black px-3 py-1.5 text-[10px] hover:bg-[#FF5722] hover:text-white\" title=\"Delete\" data-kid=\"112\">[ DEL ]</button>\n                </div>\n              </td>\n            </tr>\n\n            \n            <tr class=\"bg-[#F5F5F0]\" data-kid=\"113\">\n              <td colspan=\"5\" class=\"p-0 border-b-2 border-black\" data-kid=\"114\">\n                <div class=\"p-10 grid grid-cols-12 gap-12 relative\" data-kid=\"115\">\n                  \n                  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/crosshair.svg\" class=\"absolute top-4 left-4 w-6 h-6 opacity-20\" style=\"filter: invert(1);\" data-kid=\"116\">\n                  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/crosshair.svg\" class=\"absolute bottom-4 right-4 w-6 h-6 opacity-20\" style=\"filter: invert(1);\" data-kid=\"117\">\n                  \n                  \n                  <div class=\"col-span-3\" data-kid=\"118\">\n                    <div class=\"border-2 border-black bg-white p-1.5 neo-shadow\" data-kid=\"119\">\n                       <img src=\"https://images.unsplash.com/photo-1506863530036-1efeddceb993?auto=format&w=500&q=80&fit=crop\" alt=\"Portrait Large\" class=\"w-full aspect-[4/5] object-cover grayscale border border-black\" decoding=\"async\" loading=\"lazy\" data-kid=\"120\">\n                    </div>\n                  </div>\n                  \n                  <div class=\"col-span-9 grid grid-cols-3 gap-y-8 gap-x-12\" data-kid=\"121\">\n                    <div class=\"space-y-1\" data-kid=\"122\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"123\">DESIGNATION</p>\n                      <p class=\"font-bold text-lg uppercase tracking-tighter\" data-kid=\"124\">Senior Systems Architect</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"125\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"126\">SALARY_TIER</p>\n                      <p class=\"font-bold text-lg font-mono uppercase tracking-tighter\" data-kid=\"127\">$142,500.00 <span class=\"text-xs\" data-kid=\"128\">USD</span></p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"129\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"130\">CONTACT_EXT</p>\n                      <p class=\"font-bold text-lg font-mono uppercase tracking-tighter\" data-kid=\"131\">+1 (555) 012-9922</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"132\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"133\">MANAGER_REF</p>\n                      <p class=\"font-bold text-lg uppercase tracking-tighter\" data-kid=\"134\">Sarah Mitchell [MGR_L9]</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"135\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"136\">JOIN_DATE</p>\n                      <p class=\"font-bold text-lg font-mono uppercase tracking-tighter\" data-kid=\"137\">2021-08-14</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"138\">\n                      <p class=\"text-[10px] font-mono text-gray-500 font-bold uppercase tracking-widest\" data-kid=\"139\">CLEARANCE</p>\n                      <p class=\"font-bold text-lg uppercase tracking-tighter\" data-kid=\"140\">LEVEL_7_ADMIN</p>\n                    </div>\n                    \n                    <div class=\"col-span-3 pt-6 flex gap-4\" data-kid=\"141\">\n                      <button class=\"btn-brutal px-8 py-4 text-[10px] tracking-[0.2em] bg-black text-white\" data-kid=\"142\">GENERATE_PERFORMANCE_REPORT</button>\n                      <button class=\"btn-brutal bg-white text-black px-8 py-4 text-[10px] tracking-[0.2em]\" data-kid=\"143\">VIEW_HISTORY_LOG</button>\n                    </div>\n                  </div>\n                </div>\n              </td>\n            </tr>\n\n            \n            <tr class=\"table-row-hover group cursor-pointer\" data-kid=\"144\">\n              <td class=\"p-5 font-mono text-sm border-r-2 border-black\" data-kid=\"145\">#001025</td>\n              <td class=\"p-5 border-r-2 border-black\" data-kid=\"146\">\n                <div class=\"flex items-center gap-4\" data-kid=\"147\">\n                  <div class=\"w-10 h-10 border-2 border-black bg-white flex-shrink-0\" data-kid=\"148\">\n                    <img src=\"https://images.unsplash.com/photo-1558730234-d8b2281b0d00?auto=format&w=200&q=80&fit=crop\" alt=\"Miranda\" class=\"w-full h-full object-cover grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"149\">\n                  </div>\n                  <div data-kid=\"150\">\n                    <p class=\"font-bold tracking-tight text-lg leading-none uppercase\" data-kid=\"151\">Miranda Schulz</p>\n                    <p class=\"text-[10px] font-mono text-gray-500 mt-1\" data-kid=\"152\">M_SCHULZ@THEATRE.SYS</p>\n                  </div>\n                </div>\n              </td>\n              <td class=\"p-5 border-r-2 border-black\" data-kid=\"153\">