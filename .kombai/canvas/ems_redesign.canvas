a-kid=\"144\">\n            <img src=\"https://images.unsplash.com/photo-1633304690105-8ccaa01dfa06?auto=format&w=400&q=80&fit=crop\" alt=\"Insight\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"145\">\n          </div>\n          <div class=\"flex-1\" data-kid=\"146\">\n            <h4 class=\"text-2xl font-bold text-[var(--color-espresso)]\" data-kid=\"147\">Weekly Productivity</h4>\n            <p class=\"text-[var(--color-assam)]/60 text-lg mt-3 leading-relaxed\" data-kid=\"148\">Our logistics efficiency is up by <span class=\"text-[var(--color-forest)] font-black text-2xl px-1\" data-kid=\"149\">12%</span> compared to last month.</p>\n            <button class=\"mt-4 text-xs font-black text-[var(--color-assam)] uppercase tracking-[0.3em] hover:tracking-[0.4em] transition-all flex items-center\" data-kid=\"150\">\n              View Analytics <span class=\"ml-2\" data-kid=\"151\">→</span>\n            </button>\n          </div>\n        </div>\n        <div class=\"flex items-center space-x-10 group border-l border-[var(--color-assam)]/5 pl-12\" data-kid=\"152\">\n          <div class=\"w-32 h-32 rounded-[2.5rem] overflow-hidden shadow-xl group-hover:scale-105 transition-transform duration-500 border border-[var(--color-assam)]/5\" data-kid=\"153\">\n            <img src=\"https://images.unsplash.com/photo-1775300175543-96f588eca1fc?auto=format&w=400&q=80&fit=crop\" alt=\"Culture\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"154\">\n          </div>\n          <div class=\"flex-1\" data-kid=\"155\">\n            <h4 class=\"text-2xl font-bold text-[var(--color-espresso)]\" data-kid=\"156\">Culture Highlights</h4>\n            <p class=\"text-[var(--color-assam)]/60 text-lg mt-3 leading-relaxed\" data-kid=\"157\">Join the 'Latte Art Workshop' this Friday at the Roastery Commons.</p>\n            <button class=\"mt-4 text-xs font-black text-[var(--color-assam)] uppercase tracking-[0.3e