      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #1B1B1E;\n    background-color: #FFFFFF;\n    margin: 0;\n  }\n\n  .font-serif {\n    font-family: 'Newsreader', serif;\n  }\n\n  .tracked-header {\n    letter-spacing: 0.3em;\n    font-size: 9px;\n    font-weight: 800;\n    text-transform: uppercase;\n  }\n\n  .sidebar-link-active {\n    background-color: #E9ECEF;\n    color: #1B1B1E !important;\n  }\n\n  .sidebar-link:hover {\n    background-color: #E9ECEF;\n    color: #1B1B1E !important;\n  }\n\n  /* Custom scrollbar for better corporate look */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #F8F9FA;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #E9ECEF;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #D1D5DB;\n  }\n</style>\n\n<div class=\"flex bg-white\" data-kid=\"1\">\n  \n  <aside class=\"w-64 bg-[#0B2545] flex flex-col shrink-0 border-r border-[#E9ECEF] min-h-[900px]\" data-kid=\"2\">\n    <div class=\"p-8 pb-14\" data-kid=\"3\">\n      <div class=\"flex items-center gap-4 text-white\" data-kid=\"4\">\n        <div class=\"w-11 h-11 bg-white flex items-center justify-center rounded-none shadow-[4px_4px_0px_#133C55]\" data-kid=\"5\">\n          <i class=\"ti ti-briefcase text-[#0B2545] text-xl\" data-kid=\"6\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"7\">\n          <span class=\"font-serif text-2xl leading-none tracking-tight\" data-kid=\"8\">Penman</span>\n          <span class=\"text-[8px] uppercase tracking-[0.4em] text-white/40 font-bold mt-1.5\" data-kid=\"9\">Corporate EMS</span>\n        </div>\n      </div>\n    </div>\n  