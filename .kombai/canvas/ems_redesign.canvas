 class=\"space-y-2\" data-kid=\"204\">\n            <div class=\"flex justify-between items-center border-b border-black/10 pb-1\" data-kid=\"205\">\n              <span class=\"text-xs font-bold uppercase\" data-kid=\"206\">System Uptime</span>\n              <span class=\"font-mono text-xs\" data-kid=\"207\">99.98%</span>\n            </div>\n            <div class=\"flex justify-between items-center border-b border-black/10 pb-1\" data-kid=\"208\">\n              <span class=\"text-xs font-bold uppercase\" data-kid=\"209\">Database Load</span>\n              <span class=\"font-mono text-xs\" data-kid=\"210\">0.24ms</span>\n            </div>\n            <div class=\"flex justify-between items-center\" data-kid=\"211\">\n              <span class=\"text-xs font-bold uppercase\" data-kid=\"212\">Last Backup</span>\n              <span class=\"font-mono text-xs\" data-kid=\"213\">02M AGO</span>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"md:col-span-2 flex items-center justify-center\" data-kid=\"214\">\n          <div class=\"text-center space-y-2\" data-kid=\"215\">\n            <div class=\"font-mono text-[9px] uppercase tracking-[0.5em] text-[#FF5722] font-bold\" data-kid=\"216\">PROUDLY_OPERATED_BY</div>\n            <h4 class=\"text-3xl font-bold tracking-tighter uppercase\" data-kid=\"217\">Theatre_Collective_EMS</h4>\n            <p class=\"text-[10px] font-mono text-gray-400\" data-kid=\"218\">V_4.2.1 // STABLE_RELEASE // 2024</p>\n          </div>\n        </div>\n\n        <div class=\"space-y-4 flex flex-col items-end justify-between\" data-kid=\"219\">\n           <div class=\"flex gap-4\" data-kid=\"220\">\n             <a href=\"#\" class=\"w-10 h-10 border-2 border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors\" data-kid=\"221\">\n               <i class=\"ti ti-brand-x\" data-kid=\"222\"></i>\n             </a>\n             <a href=\"#\" class=\"w-10 h-10 border-2 border-black flex items-center justify-center hover:bg-black hover:text-white transition-colors\" data-kid=\"223\">\n               <i class=\"ti ti-brand-github\" data-kid=\"224\"></i>\n             </a>\n           </div>\n           <p class=\"text-[10px] font-mono text-gray-500 uppercase tracking-widest\" data-kid=\"225\">© ALL_RIGHTS_RESERVED_2024</p>\n        </div>\n      </footer>\n\n    </main>\n  </div>\n</body>\n",
